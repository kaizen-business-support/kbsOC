# Database
DATABASE_URL="postgresql://optimus:password@localhost:5432/optimus_credit?schema=public"

# Authentication
JWT_SECRET="your-super-secret-jwt-key-here-change-in-production"
JWT_REFRESH_SECRET="your-refresh-secret-key-here"
JWT_EXPIRY="1h"
JWT_REFRESH_EXPIRY="7d"

# Server Configuration
NODE_ENV="development"
PORT="3000"
API_BASE_URL="http://localhost:3000"
FRONTEND_URL="http://localhost:3001"

# File Upload
UPLOAD_PATH="./uploads"
MAX_FILE_SIZE="10485760"
ALLOWED_FILE_TYPES="pdf,png,jpg,jpeg,xlsx,xls,doc,docx"

# Email Configuration (Optional)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="noreply@yourbank.com"
SMTP_PASS="your-email-password"
EMAIL_FROM="OptimusCredit <noreply@yourbank.com>"

# Security
BCRYPT_ROUNDS="12"
RATE_LIMIT_WINDOW_MS="900000"
RATE_LIMIT_MAX_REQUESTS="100"

# Chiffrement des configs fournisseurs de signature électronique (DocuSeal).
# 32 octets en hexadécimal (64 caractères). Génération :
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Obligatoire dès qu'un tenant active le mode signature externe.
# NE PAS PERDRE : sans cette clé, les configs chiffrées en DB sont irrécupérables.
SIGNATURE_PROVIDER_ENCRYPTION_KEY=""

# CORS Configuration
# For VM deployment, specify exact frontend URL (e.g., "http://192.168.1.100:3006")
# For multiple origins, separate with commas: "http://192.168.1.100:3006,http://192.168.1.101:3006"
# Use "*" ONLY in development to allow all origins
ALLOWED_ORIGINS="http://localhost:3001,http://localhost:3000"

# Logging
LOG_LEVEL="info"
LOG_FILE="logs/app.log"

# External APIs (Optional)
INDUSTRY_BENCHMARK_API_URL=""
INDUSTRY_BENCHMARK_API_KEY=""

# OCR Configuration (Optional)
OCR_SERVICE_ENABLED="false"
OCR_SERVICE_URL="http://localhost:3002"

# Azure AD (Optional - for SSO)
AZURE_TENANT_ID=""
AZURE_CLIENT_ID=""
AZURE_CLIENT_SECRET=""

# Development Flags
ENABLE_API_DOCS="true"
ENABLE_SEED_DATA="true"
DISABLE_AUTH_FOR_TESTING="false"

# Brute-Force Detection (Phase 5)
BF_THRESHOLD="5"              # nombre d'échecs déclenchant le verrouillage
BF_WINDOW_SEC="300"           # fenêtre d'observation (5 minutes)
BF_BLOCK_DURATION_SEC="900"   # durée du verrouillage (15 minutes)