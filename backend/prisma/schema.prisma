// ─── Suivi des remboursements ──────────────────────────────────────────────────

model RepaymentEntry {
  id                String            @id @default(cuid())
  applicationId     String            @map("application_id")
  companyId         String?           @map("company_id")
  periodNumber      Int               @map("period_number") // n° de l'échéance (1-based)
  dueDate           DateTime          @map("due_date")
  expectedAmount    Decimal           @map("expected_amount") @db.Decimal(15, 2)
  expectedPrincipal Decimal           @map("expected_principal") @db.Decimal(15, 2)
  expectedInterest  Decimal           @map("expected_interest") @db.Decimal(15, 2)
  status            RepaymentStatus   @default(PENDING)
  paidAmount        Decimal?          @map("paid_amount") @db.Decimal(15, 2)
  paidAt            DateTime?         @map("paid_at")
  verifiedById      String?           @map("verified_by_id")
  verifiedAt        DateTime?         @map("verified_at")
  notes             String?
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  application       CreditApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  verifiedBy        User?             @relation("UserVerifiedRepayments", fields: [verifiedById], references: [id])

  @@unique([applicationId, periodNumber])
  @@index([applicationId])
  @@index([companyId])
  @@map("repayment_entries")
}

enum RepaymentStatus {
  PENDING @map("pending") // Non encore échu ou non encore vérifié
  PAID    @map("paid") // Réglé (vérifié sur SIB)
  LATE    @map("late") // Date dépassée et non réglé
  PARTIAL @map("partial") // Paiement partiel

  @@map("repayment_status")
}

model BackupNotifyEmail {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("backup_notify_emails")
}

// ─── Notification Models ───────────────────────────────────────────────────────

model NotificationChannel {
  id        String                 @id @default(cuid())
  type      ChannelType            @unique
  name      String
  isActive  Boolean                @default(false) @map("is_active")
  config    Json // SMTP params or { provider, apiKey, senderId, baseUrl }
  createdAt DateTime               @default(now()) @map("created_at")
  updatedAt DateTime               @updatedAt @map("updated_at")
  templates NotificationTemplate[]

  @@map("notification_channels")
}

model NotificationTemplate {
  id        String              @id @default(cuid())
  name      String
  event     NotifEvent
  channelId String              @map("channel_id")
  channel   NotificationChannel @relation(fields: [channelId], references: [id])
  subject   String? // email only
  body      String // with {{clientName}} {{applicationNumber}} etc.
  isActive  Boolean             @default(true) @map("is_active")
  createdAt DateTime            @default(now()) @map("created_at")
  updatedAt DateTime            @updatedAt @map("updated_at")
  rules     NotificationRule[]

  @@map("notification_templates")
}

model NotificationRule {
  id             String               @id @default(cuid())
  event          NotifEvent
  templateId     String               @map("template_id")
  template       NotificationTemplate @relation(fields: [templateId], references: [id])
  recipientRoles Json // ["ACCOUNT_MANAGER", "CREDIT_ANALYST", ...]
  isActive       Boolean              @default(true) @map("is_active")
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")

  @@unique([event, templateId])
  @@map("notification_rules")
}

model Notification {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  user        User      @relation("UserNotifications", fields: [userId], references: [id])
  title       String
  message     String
  type        NotifType @default(INFO)
  relatedType String?   @map("related_type")
  relatedId   String?   @map("related_id")
  actionUrl   String?   @map("action_url")
  isRead      Boolean   @default(false) @map("is_read")
  companyId   String?   @map("company_id")
  company     Company?  @relation(fields: [companyId], references: [id])
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([userId, isRead])
  @@index([companyId])
  @@map("notifications")
}

enum ChannelType {
  EMAIL
  SMS

  @@map("channel_type")
}

enum NotifEvent {
  APPLICATION_SUBMITTED
  STEP_ASSIGNED
  STEP_APPROVED
  STEP_REJECTED
  APPLICATION_APPROVED
  APPLICATION_REJECTED
  STEP_OVERDUE // Délai maximum dépassé sur une étape
  STEP_PENDING_REMINDER // Rappel : action en attente depuis un certain temps

  @@map("notif_event")
}

enum NotifType {
  INFO
  ACTION_REQUIRED
  SUCCESS
  WARNING

  @@map("notif_type")
}

// ─── File d'attente des emails ─────────────────────────────────────────────────

enum EmailQueueStatus {
  PENDING
  SENDING
  SENT
  FAILED

