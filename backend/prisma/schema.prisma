generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String              @id @default(cuid())
  email               String              @unique
  passwordHash        String?             @map("password_hash")
  name                String
  role                UserRole            @default(ACCOUNT_MANAGER)
  department          String?
  jobTitle            String?             @map("job_title")
  phone               String?
  permissions         Json?
  isActive            Boolean             @default(true) @map("is_active")
  azureId             String?             @unique @map("azure_id")
  lastLogin           DateTime?           @map("last_login")
  // 2FA fields
  twoFactorEnabled    Boolean             @default(false) @map("two_factor_enabled")
  twoFactorSecret     String?             @map("two_factor_secret")
  backupCodes         String[]            @default([]) @map("backup_codes")
  twoFactorRequired   Boolean             @default(false) @map("two_factor_required") // admin can force per-user
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")
  auditLogs           AuditLog[]
  createdClients      Client[]            @relation("UserCreatedClients")
  createdApplications CreditApplication[] @relation("UserCreatedApplications")
  uploadedDocuments   Document[]          @relation("UserUploadedDocuments")
  assignedSteps       WorkflowStep[]      @relation("UserAssignedSteps")
  announcements       Announcement[]      @relation("UserCreatedAnnouncements")

  @@map("users")
}

model Announcement {
  id          String              @id @default(cuid())
  title       String
  message     String
  priority    AnnouncementPriority @default(INFO)
  isActive    Boolean             @default(true) @map("is_active")
  expiresAt   DateTime            @map("expires_at")
  createdBy   String              @map("created_by")
  creator     User                @relation("UserCreatedAnnouncements", fields: [createdBy], references: [id])
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  @@map("announcements")
}

model Client {
  id              String              @id @default(cuid())
  companyName     String              @map("company_name")
  rccm            String?             @unique
  ninea           String?             @unique
  cofi            String?
  legalForm       String?             @map("legal_form")
  sector          String?
  establishedYear Int?                @map("established_year")
  headquarters    String?
  contactPerson   String?             @map("contact_person")
  phone           String?
  email           String?
  isActive        Boolean             @default(true) @map("is_active")
  createdBy       String              @map("created_by")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")
  creator         User                @relation("UserCreatedClients", fields: [createdBy], references: [id])
  applications    CreditApplication[]
  financialData   FinancialData[]

  @@map("clients")
}

model CreditApplication {
  id                String             @id @default(cuid())
  applicationNumber String             @unique @map("application_number")
  clientId          String             @map("client_id")
  amount            Decimal            @db.Decimal(15, 2)
  currency          String             @default("XOF")
  purpose           String
  durationMonths    Int?               @map("duration_months")
  creditTypeId      String?            @map("credit_type_id")
  proposedRate      Decimal?           @map("proposed_rate") @db.Decimal(5, 2)
  collateralType    String?            @map("collateral_type")
  collateralValue   Decimal?           @map("collateral_value") @db.Decimal(15, 2)
  repaymentSchedule RepaymentSchedule? @map("repayment_schedule")
  status            ApplicationStatus  @default(DRAFT)
  score             Json?
  analysisResults   Json?              @map("analysis_results")
  submittedAt       DateTime?          @map("submitted_at")
  createdBy         String             @map("created_by")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  auditLogs         AuditLog[]
  client            Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  creator           User               @relation("UserCreatedApplications", fields: [createdBy], references: [id])
  creditType        CreditType?        @relation(fields: [creditTypeId], references: [id])
  documents         Document[]
  workflowSteps     WorkflowStep[]

  @@index([status])
  @@index([clientId])
  @@map("credit_applications")
}

model FinancialData {
  id           String          @id @default(cuid())
  clientId     String          @map("client_id")
  year         Int
  period       FinancialPeriod @default(ANNUAL)
  accountName  String          @map("account_name")
  accountValue Decimal         @map("account_value") @db.Decimal(15, 2)
  category     String?
  createdAt    DateTime        @default(now()) @map("created_at")
  client       Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, year, period, accountName])
  @@map("financial_data")
}

model Document {
  id            String            @id @default(cuid())
  applicationId String            @map("application_id")
  filename      String
  filePath      String            @map("file_path")
  fileSize      Int?              @map("file_size")
  mimeType      String?           @map("mime_type")
  category      DocumentCategory  @default(OTHER)
  ocrText       String?           @map("ocr_text")
  extractedData Json?             @map("extracted_data")
  status        DocumentStatus    @default(PENDING)
  uploadedBy    String            @map("uploaded_by")
  createdAt     DateTime          @default(now()) @map("created_at")
  application   CreditApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  uploader      User              @relation("UserUploadedDocuments", fields: [uploadedBy], references: [id])

  @@map("documents")
}

model WorkflowStep {
  id            String            @id @default(cuid())
  applicationId String            @map("application_id")
  stepName      String            @map("step_name")
  role          UserRole
  assigneeId    String?           @map("assignee_id")
  status        StepStatus        @default(PENDING)
  deadline      DateTime?
  comments      String?
  decision      String?
  completedAt   DateTime?         @map("completed_at")
  createdAt     DateTime          @default(now()) @map("created_at")
  application   CreditApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  assignee      User?             @relation("UserAssignedSteps", fields: [assigneeId], references: [id])

  @@index([applicationId])
  @@index([status])
  @@map("workflow_steps")
}

model AuditLog {
  id            String             @id @default(cuid())
  userId        String             @map("user_id")
  applicationId String?            @map("application_id")
  action        String
  entityType    String             @map("entity_type")
  entityId      String             @map("entity_id")
  oldValues     Json?              @map("old_values")
  newValues     Json?              @map("new_values")
  ipAddress     String?            @map("ip_address")
  userAgent     String?            @map("user_agent")
  createdAt     DateTime           @default(now()) @map("created_at")
  application   CreditApplication? @relation(fields: [applicationId], references: [id])
  user          User               @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

model WorkflowStepConfig {
  id               String   @id @default(cuid())
  stepName         String   @unique @map("step_name")
  displayName      String   @map("display_name")
  expectedDuration Int      @map("expected_duration") // in minutes
  maxDuration      Int?     @map("max_duration") // in minutes
  description      String?
  stepType         StepType @default(FIXED) @map("step_type") // FIXED or APPROVAL
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("workflow_step_configs")
}

model ApprovalLimit {
  id                String   @id @default(cuid())
  role              UserRole @unique
  displayName       String   @map("display_name")
  minAmount         Decimal  @map("min_amount") @db.Decimal(15, 2)
  maxAmount         Decimal  @map("max_amount") @db.Decimal(15, 2)
  currency          String   @default("XOF")
  reviewDuration    Int      @map("review_duration") // Time in minutes for this role to review
  maxReviewDuration Int?     @map("max_review_duration") // Max time before escalation
  description       String?
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("approval_limits")
}

model CreditType {
  id              String              @id @default(cuid())
  name            String              @unique
  code            String              @unique
  description     String?
  defaultRate     Decimal             @map("default_rate") @db.Decimal(5, 2)
  minRate         Decimal?            @map("min_rate") @db.Decimal(5, 2)
  maxRate         Decimal?            @map("max_rate") @db.Decimal(5, 2)
  minDuration     Int?                @map("min_duration")
  maxDuration     Int?                @map("max_duration")
  requiresCollateral Boolean          @default(false) @map("requires_collateral")
  isActive        Boolean             @default(true) @map("is_active")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")
  applications    CreditApplication[]

  @@map("credit_types")
}

model Department {
  id          String   @id @default(cuid())
  name        String   @unique
  code        String   @unique
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("departments")
}

model Branch {
  id        String   @id @default(cuid())
  name      String   @unique
  code      String   @unique
  address   String?
  city      String?
  country   String?  @default("Sénégal")
  manager   String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("branches")
}

model RolePermission {
  id                String   @id @default(cuid())
  role              UserRole @unique
  label             String
  description       String?
  permissions       Json     // Array of permission strings
  twoFactorRequired Boolean  @default(false) @map("two_factor_required") // admin forces 2FA for all users of this role
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("role_permissions")
}

model BackupLog {
  id        String   @id @default(uuid())
  filename  String
  type      String   // 'full' | 'partial'
  size      Int      @default(0)
  status    String   // 'success' | 'failed'
  error     String?
  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("backup_logs")
}

enum UserRole {
  ACCOUNT_MANAGER  @map("account_manager")
  CREDIT_ANALYST   @map("credit_analyst")
  BRANCH_MANAGER   @map("branch_manager")
  CREDIT_COMMITTEE @map("credit_committee")
  MANAGEMENT       @map("management")
  ADMIN            @map("admin")

  @@map("user_role")
}

enum ApplicationStatus {
  DRAFT        @map("draft")
  SUBMITTED    @map("submitted")
  UNDER_REVIEW @map("under_review")
  APPROVED     @map("approved")
  REJECTED     @map("rejected")
  DISBURSED    @map("disbursed")

  @@map("application_status")
}

enum RepaymentSchedule {
  MONTHLY    @map("monthly")
  QUARTERLY  @map("quarterly")
  SEMIANNUAL @map("semiannual")
  ANNUAL     @map("annual")

  @@map("repayment_schedule")
}

enum FinancialPeriod {
  ANNUAL    @map("annual")
  SEMESTER  @map("semester")
  QUARTERLY @map("quarterly")

  @@map("financial_period")
}

enum DocumentCategory {
  FINANCIAL  @map("financial")
  LEGAL      @map("legal")
  IDENTITY   @map("identity")
  COLLATERAL @map("collateral")
  OTHER      @map("other")

  @@map("document_category")
}

enum DocumentStatus {
  PROCESSING @map("processing")
  VERIFIED   @map("verified")
  ERROR      @map("error")
  PENDING    @map("pending")

  @@map("document_status")
}

enum StepStatus {
  PENDING   @map("pending")
  IN_REVIEW @map("in_review")
  APPROVED  @map("approved")
  REJECTED  @map("rejected")
  COMPLETED @map("completed")

  @@map("step_status")
}

enum AnnouncementPriority {
  INFO    @map("info")
  WARNING @map("warning")
  URGENT  @map("urgent")

  @@map("announcement_priority")
}

enum StepType {
  FIXED    @map("fixed")     // Fixed workflow steps (application_created, credit_analysis, etc.)
  APPROVAL @map("approval")  // Dynamic approval steps based on amount thresholds

  @@map("step_type")
}
