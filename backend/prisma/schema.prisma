generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id                      String   @id @default(cuid())
  name                    String
  code                    String   @unique
  logoUrl                 String?  @map("logo_url")
  isActive                Boolean  @default(true) @map("is_active")
  signatureProviderConfig Json?    @map("signature_provider_config")
  legalRepresentative     String?  @map("legal_representative")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  memberships          CompanyMembership[]
  clients              Client[]
  applications         CreditApplication[]
  policies             CreditPolicy[]
  creditTypes          CreditType[]
  approvalLimits       ApprovalLimit[]
  delegations          PowerDelegation[]
  notifications        Notification[]
  announcements        Announcement[]
  departments          Department[]
  branches             Branch[]
  chineseWallRules     TenantChineseWallRule[]
  contractTemplates    ContractTemplate[]
  moduleProfiles       ModuleProfile[]
  userModuleOverrides  UserModuleOverride[]
  scopeDelegates       ScopeDelegate[]
  securityIpRules      SecurityIpRule[]
  securityTimeRules    SecurityTimeRule[]
  securityBlockHistory SecurityBlockHistory[]

  @@map("companies")
}

model CompanyMembership {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  companyId String   @map("company_id")
  role      UserRole
  isActive  Boolean  @default(true) @map("is_active")
  joinedAt  DateTime @default(now()) @map("joined_at")

  user    User    @relation(fields: [userId], references: [id])
  company Company @relation(fields: [companyId], references: [id])

  @@unique([userId, companyId])
  @@index([companyId])
  @@index([userId])
  @@map("company_memberships")
}

model User {
  id                       String                 @id @default(cuid())
  email                    String                 @unique
  passwordHash             String?                @map("password_hash")
  name                     String
  role                     UserRole               @default(CHARGE_AFFAIRES)
  department               String?
  branch                   String?
  jobTitle                 String?                @map("job_title")
  phone                    String?
  permissions              Json?
  isActive                 Boolean                @default(true) @map("is_active")
  isOnLeave                Boolean                @default(false) @map("is_on_leave")
  azureId                  String?                @unique @map("azure_id")
  lastLogin                DateTime?              @map("last_login")
  onboardingCompletedAt    DateTime?              @map("onboarding_completed_at")
  // 2FA fields
  twoFactorEnabled         Boolean                @default(false) @map("two_factor_enabled")
  twoFactorSecret          String?                @map("two_factor_secret")
  backupCodes              String[]               @default([]) @map("backup_codes")
  twoFactorRequired        Boolean                @default(false) @map("two_factor_required") // admin can force per-user
  // Password lifecycle fields
  mustChangePassword       Boolean                @default(false) @map("must_change_password")
  passwordExpiresAt        DateTime?              @map("password_expires_at")
  passwordResetToken       String?                @map("password_reset_token")
  passwordResetExpires     DateTime?              @map("password_reset_expires")
  createdAt                DateTime               @default(now()) @map("created_at")
  updatedAt                DateTime               @updatedAt @map("updated_at")
  auditLogs                AuditLog[]
  createdClients           Client[]               @relation("UserCreatedClients")
  createdApplications      CreditApplication[]    @relation("UserCreatedApplications")
  uploadedDocuments        Document[]             @relation("UserUploadedDocuments")
  assignedSteps            WorkflowStep[]         @relation("UserAssignedSteps")
  verifiedRepayments       RepaymentEntry[]       @relation("UserVerifiedRepayments")
  announcements            Announcement[]         @relation("UserCreatedAnnouncements")
  notifications            Notification[]         @relation("UserNotifications")
  delegationsGiven         PowerDelegation[]      @relation("DelegatorRelation")
  delegationsReceived      PowerDelegation[]      @relation("DelegateRelation")
  delegationsCreated       PowerDelegation[]      @relation("DelegationCreatedBy")
  delegationsRevoked       PowerDelegation[]      @relation("DelegationRevokedBy")
  memberships              CompanyMembership[]
  generatedContracts       GeneratedContract[]    @relation("UserGeneratedContracts")
  createdModuleProfiles    ModuleProfile[]        @relation("ModuleProfileCreatedBy")
  moduleOverrides          UserModuleOverride[]
  createdOverrides         UserModuleOverride[]   @relation("OverrideCreatedBy")
  scopeDelegationsGiven    ScopeDelegate[]        @relation("ScopeDelegatorRel")
  scopeDelegationsReceived ScopeDelegate[]        @relation("ScopeDelegateRel")
  scopeDelegationsRevoked  ScopeDelegate[]        @relation("ScopeRevokedBy")
  createdIpRules           SecurityIpRule[]       @relation("UserCreatedIpRules")
  createdTimeRules         SecurityTimeRule[]     @relation("UserCreatedTimeRules")
  blockAttempts            SecurityBlockHistory[] @relation("UserBlockAttempts")
  unblocksPerformed        SecurityBlockHistory[] @relation("UserUnblocks")

  @@map("users")
}

model Announcement {
  id        String               @id @default(cuid())
  title     String
  message   String
  priority  AnnouncementPriority @default(INFO)
  isActive  Boolean              @default(true) @map("is_active")
  expiresAt DateTime             @map("expires_at")
  createdBy String               @map("created_by")
  creator   User                 @relation("UserCreatedAnnouncements", fields: [createdBy], references: [id])
  companyId String?              @map("company_id")
  company   Company?             @relation(fields: [companyId], references: [id])
  createdAt DateTime             @default(now()) @map("created_at")
  updatedAt DateTime             @updatedAt @map("updated_at")

  @@index([companyId])
  @@map("announcements")
}

model Client {
  id              String              @id @default(cuid())
  companyName     String              @map("company_name")
  branch          String?             @map("branch")
  rccm            String?
  ninea           String?
  cofi            String?
  legalForm       String?             @map("legal_form")
  sector          String?
  establishedYear Int?                @map("established_year")
  headquarters    String?
  contactPerson   String?             @map("contact_person")
  phone           String?
  email           String?
  accountNumber   String?             @unique @map("account_number")
  isActive        Boolean             @default(true) @map("is_active")
  createdBy       String              @map("created_by")
  companyId       String?             @map("company_id")
  company         Company?            @relation(fields: [companyId], references: [id])
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")
  creator         User                @relation("UserCreatedClients", fields: [createdBy], references: [id])
  applications    CreditApplication[]
  financialData   FinancialData[]

  @@unique([companyId, rccm])
  @@unique([companyId, ninea])
  @@index([companyId])
  @@map("clients")
}

model CreditApplication {
  id                   String              @id @default(cuid())
  applicationNumber    String              @unique @map("application_number")
  clientId             String              @map("client_id")
  amount               Decimal             @db.Decimal(15, 2)
  currency             String              @default("XOF")
  purpose              String
  durationMonths       Int?                @map("duration_months")
  creditTypeId         String?             @map("credit_type_id")
  proposedRate         Decimal?            @map("proposed_rate") @db.Decimal(5, 2)
  collateralType       String?             @map("collateral_type")
  collateralValue      Decimal?            @map("collateral_value") @db.Decimal(15, 2)
  repaymentSchedule    RepaymentSchedule?  @map("repayment_schedule")
  status               ApplicationStatus   @default(DRAFT)
  score                Json?
  analysisResults      Json?               @map("analysis_results")
  submittedAt          DateTime?           @map("submitted_at")
  // Politique de crédit appliquée à ce dossier
  policyId             String?             @map("policy_id")
  policy               CreditPolicy?       @relation(fields: [policyId], references: [id])
  // Durée totale de traitement (calculée à la clôture : APPROVED/REJECTED)
  totalDurationMinutes Int?                @map("total_duration_minutes")
  createdBy            String              @map("created_by")
  companyId            String?             @map("company_id")
  company              Company?            @relation(fields: [companyId], references: [id])
  createdAt            DateTime            @default(now()) @map("created_at")
  updatedAt            DateTime            @updatedAt @map("updated_at")
  auditLogs            AuditLog[]
  client               Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  creator              User                @relation("UserCreatedApplications", fields: [createdBy], references: [id])
  creditType           CreditType?         @relation(fields: [creditTypeId], references: [id])
  documents            Document[]
  workflowSteps        WorkflowStep[]
  generatedContracts   GeneratedContract[]
  repaymentEntries     RepaymentEntry[]

  @@index([status])
  @@index([clientId])
  @@index([companyId])
  @@map("credit_applications")
}

model FinancialData {
  id           String          @id @default(cuid())
  clientId     String          @map("client_id")
  year         Int
  period       FinancialPeriod @default(ANNUAL)
  accountName  String          @map("account_name")
  accountValue Decimal         @map("account_value") @db.Decimal(15, 2)
  category     String?
  createdAt    DateTime        @default(now()) @map("created_at")
  client       Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, year, period, accountName])
  @@map("financial_data")
}

model Document {
  id            String             @id @default(cuid())
  applicationId String             @map("application_id")
  filename      String
  filePath      String             @map("file_path")
  fileSize      Int?               @map("file_size")
  mimeType      String?            @map("mime_type")
  category      DocumentCategory   @default(OTHER)
  ocrText       String?            @map("ocr_text")
  extractedData Json?              @map("extracted_data")
  status        DocumentStatus     @default(PENDING)
  uploadedBy    String             @map("uploaded_by")
  createdAt     DateTime           @default(now()) @map("created_at")
  application   CreditApplication  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  uploader      User               @relation("UserUploadedDocuments", fields: [uploadedBy], references: [id])
  contractRef   GeneratedContract? @relation("ContractDocument")

  @@map("documents")
}

model WorkflowStep {
  id              String            @id @default(cuid())
  applicationId   String            @map("application_id")
  stepName        String            @map("step_name")
  role            String
  assigneeId      String?           @map("assignee_id")
  status          StepStatus        @default(PENDING)
  deadline        DateTime?
  comments        String?
  decision        String?
  completedAt     DateTime?         @map("completed_at")
  // Lien vers l'étape de politique qui a généré cette instance
  policyStepId    String?           @map("policy_step_id")
  policyStep      CreditPolicyStep? @relation(fields: [policyStepId], references: [id])
  // Tracking du temps de traitement
  startedAt       DateTime?         @map("started_at") // Quand l'utilisateur a commencé
  durationMinutes Int?              @map("duration_minutes") // Durée effective en minutes
  // Alertes SLA
  isOverdue       Boolean           @default(false) @map("is_overdue")
  overdueAt       DateTime?         @map("overdue_at") // Quand le délai max a été dépassé
  notifiedAt      DateTime?         @map("notified_at") // Quand la notif a été envoyée
  isEscalated     Boolean           @default(false) @map("is_escalated")
  escalatedAt     DateTime?         @map("escalated_at")
  escalatedById   String?           @map("escalated_by_id")
  lastRelancedAt  DateTime?         @map("last_relanced_at")
  createdAt       DateTime          @default(now()) @map("created_at")
  application     CreditApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  assignee        User?             @relation("UserAssignedSteps", fields: [assigneeId], references: [id])

  @@index([applicationId])
  @@index([status])
  @@map("workflow_steps")
}

model AuditLog {
  id            String             @id @default(cuid())
  userId        String             @map("user_id")
  applicationId String?            @map("application_id")
  action        String
  entityType    String             @map("entity_type")
  entityId      String             @map("entity_id")
  oldValues     Json?              @map("old_values")
  newValues     Json?              @map("new_values")
  ipAddress     String?            @map("ip_address")
  userAgent     String?            @map("user_agent")
  createdAt     DateTime           @default(now()) @map("created_at")
  application   CreditApplication? @relation(fields: [applicationId], references: [id])
  user          User               @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

model WorkflowStepConfig {
  id               String   @id @default(cuid())
  stepName         String   @unique @map("step_name")
  displayName      String   @map("display_name")
  expectedDuration Int      @map("expected_duration") // in minutes
  maxDuration      Int?     @map("max_duration") // in minutes
  description      String?
  stepType         StepType @default(FIXED) @map("step_type") // FIXED or APPROVAL
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("workflow_step_configs")
}

model ApprovalLimit {
  id                String   @id @default(cuid())
  role              UserRole
  displayName       String   @map("display_name")
  minAmount         Decimal  @map("min_amount") @db.Decimal(15, 2)
  maxAmount         Decimal  @map("max_amount") @db.Decimal(15, 2)
  currency          String   @default("XOF")
  order             Int      @default(1) // Niveau hiérarchique : 1=premier, 2=deuxième, etc.
  reviewDuration    Int      @map("review_duration") // Durée en minutes pour ce rôle
  maxReviewDuration Int?     @map("max_review_duration") // Durée max avant escalade
  description       String?
  isActive          Boolean  @default(true) @map("is_active")
  companyId         String?  @map("company_id")
  company           Company? @relation(fields: [companyId], references: [id])
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@unique([companyId, role])
  @@index([companyId])
  @@map("approval_limits")
}

model CreditType {
  id                 String                   @id @default(cuid())
  name               String
  code               String
  description        String?
  defaultRate        Decimal                  @map("default_rate") @db.Decimal(5, 2)
  minRate            Decimal?                 @map("min_rate") @db.Decimal(5, 2)
  maxRate            Decimal?                 @map("max_rate") @db.Decimal(5, 2)
  minDuration        Int?                     @map("min_duration")
  maxDuration        Int?                     @map("max_duration")
  requiresCollateral Boolean                  @default(false) @map("requires_collateral")
  isActive           Boolean                  @default(true) @map("is_active")
  companyId          String?                  @map("company_id")
  company            Company?                 @relation(fields: [companyId], references: [id])
  createdAt          DateTime                 @default(now()) @map("created_at")
  updatedAt          DateTime                 @updatedAt @map("updated_at")
  applications       CreditApplication[]
  workflowSteps      CreditTypeWorkflowStep[]

  @@unique([companyId, name])
  @@unique([companyId, code])
  @@index([companyId])
  @@map("credit_types")
}

model CreditTypeWorkflowStep {
  id                 String     @id @default(cuid())
  creditTypeId       String     @map("credit_type_id")
  stepName           String     @map("step_name")
  stepLabel          String     @map("step_label")
  role               UserRole
  order              Int
  isRequired         Boolean    @default(true) @map("is_required")
  durationDays       Int        @default(3) @map("duration_days")
  description        String?
  // Conditions dynamiques sur le montant (null = étape toujours obligatoire)
  conditionMinAmount Decimal?   @map("condition_min_amount") @db.Decimal(15, 2)
  conditionMaxAmount Decimal?   @map("condition_max_amount") @db.Decimal(15, 2)
  creditType         CreditType @relation(fields: [creditTypeId], references: [id], onDelete: Cascade)

  @@unique([creditTypeId, order])
  @@map("credit_type_workflow_steps")
}

// ─── Politique de Crédit ─────────────────────────────────────────────────────

/**
 * CreditPolicy — conteneur principal de la politique de crédit.
 * Une politique regroupe toutes les étapes du circuit de traitement
 * (dispatch, analyse, approbation, comité) avec les profils responsables,
 * les délais et les plafonds de validation.
 * Elle remplace la combinaison CreditTypeWorkflowStep + ApprovalLimit + WorkflowStepConfig.
 */
model CreditPolicy {
  id          String       @id @default(cuid())
  name        String // "Politique Générale de Crédit 2024"
  code        String // "POL-2024-001"
  description String?
  isActive    Boolean      @default(false) @map("is_active")
  status      PolicyStatus @default(DRAFT)
  version     Int          @default(1)
  validFrom   DateTime     @default(now()) @map("valid_from")
  validTo     DateTime?    @map("valid_to")
  companyId   String?      @map("company_id")
  company     Company?     @relation(fields: [companyId], references: [id])
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  steps        CreditPolicyStep[]
  applications CreditApplication[]

  @@unique([companyId, code])
  @@index([companyId])
  @@map("credit_policies")
}

/**
 * CreditPolicyStep — une étape dans la politique de crédit.
 * Chaque étape définit :
 * - stepType    : le rôle fonctionnel de l'étape (DISPATCH / ANALYSIS / APPROVAL / COMMITTEE)
 * - assignedRole: le profil responsable de cette étape (String libre pour rôles dynamiques)
 * - conditions  : plages de montant pour activer l'étape (null = toujours actif)
 * - limites     : plafonds que ce profil peut approuver (pour APPROVAL/COMMITTEE)
 * - délais      : SLA attendu et maximum (en heures) → base des alertes
 * - creditTypeIds : types de crédit auxquels s'applique cette étape (vide = tous)
 */
model CreditPolicyStep {
  id       String       @id @default(cuid())
  policyId String       @map("policy_id")
  policy   CreditPolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  stepName  String         @map("step_name") // slug: "dispatch", "credit_analysis", "supervisor_approval"
  stepLabel String         @map("step_label") // libellé affiché: "Dispatching", "Analyse Crédit", …
  order     Int
  stepType  PolicyStepType @map("step_type")

  // Profil responsable de cette étape (String pour accepter les rôles personnalisés)
  assignedRole String @map("assigned_role")

  // Condition d'activation (montant du dossier) — null = toujours actif
  conditionMinAmount Decimal? @map("condition_min_amount") @db.Decimal(15, 2)
  conditionMaxAmount Decimal? @map("condition_max_amount") @db.Decimal(15, 2)

  // Plafonds de validation de ce profil (pour étapes APPROVAL / COMMITTEE)
  approvalMinAmount Decimal? @map("approval_min_amount") @db.Decimal(15, 2)
  approvalMaxAmount Decimal? @map("approval_max_amount") @db.Decimal(15, 2)

  // SLA en heures
  expectedDurationHours Int @default(24) @map("expected_duration_hours")
  maxDurationHours      Int @default(72) @map("max_duration_hours")

  isRequired     Boolean  @default(true) @map("is_required")
  isActive       Boolean  @default(true) @map("is_active")
  description    String?
  allowedActions String[] @default([]) @map("allowed_actions")

  // Types de crédit auxquels s'applique cette étape (tableau vide = tous)
  creditTypeIds String[] @default([]) @map("credit_type_ids")

  // Phase d'affichage dans la matrice RACI (ex: "Montage dossier", "Analyse risques")
  phase String? @map("phase")

  // Pour les étapes DISPATCH : rôle cible vers lequel le dispatch est effectué
  dispatchTargetRole String? @map("dispatch_target_role")

  // Règles de transition conditionnelles (builder v2) — priorité sur conditionMin/MaxAmount
  guards Json? @map("guards")

  workflowSteps WorkflowStep[]
  stepRoles     CreditPolicyStepRole[]

  @@unique([policyId, order])
  @@map("credit_policy_steps")
}

model CreditPolicyStepRole {
  id           String           @id @default(cuid())
  policyStepId String           @map("policy_step_id")
  policyStep   CreditPolicyStep @relation(fields: [policyStepId], references: [id], onDelete: Cascade)
  role         UserRole
  raciCode     RaciCode         @map("raci_code")
  createdAt    DateTime         @default(now()) @map("created_at")

  @@unique([policyStepId, role])
  @@map("credit_policy_step_roles")
}

model TenantChineseWallRule {
  id            String   @id @default(cuid())
  companyId     String   @map("company_id")
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  blockedRole   UserRole @map("blocked_role")
  // Slug de l'étape interdite (ex: "contre_analyse"). Pas de FK possible car stepName n'est pas @unique.
  // ATTENTION : un slug mal orthographié crée une règle silencieuse qui ne se déclenchera jamais.
  forbiddenStep String   @map("forbidden_step")
  reason        String?
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")

  @@unique([companyId, blockedRole, forbiddenStep])
  @@map("tenant_chinese_wall_rules")
}

model Department {
  id          String   @id @default(cuid())
  name        String   @unique
  code        String   @unique
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  companyId   String?  @map("company_id")
  company     Company? @relation(fields: [companyId], references: [id])
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([companyId])
  @@map("departments")
}

model Branch {
  id        String   @id @default(cuid())
  name      String   @unique
  code      String   @unique
  address   String?
  city      String?
  country   String?  @default("Sénégal")
  manager   String?
  isActive  Boolean  @default(true) @map("is_active")
  companyId String?  @map("company_id")
  company   Company? @relation(fields: [companyId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([companyId])
  @@map("branches")
}

model RolePermission {
  id                String   @id @default(cuid())
  role              String   @unique
  label             String
  description       String?
  permissions       Json // Array of permission strings
  twoFactorRequired Boolean  @default(false) @map("two_factor_required") // admin forces 2FA for all users of this role
  isReadOnly        Boolean  @default(false) @map("is_read_only") // lecture seule : aucune action d'écriture autorisée
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("role_permissions")
}

model BackupLog {
  id        String   @id @default(uuid())
  filename  String
  type      String // 'full' | 'partial'
  size      Int      @default(0)
  status    String // 'success' | 'failed'
  error     String?
  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("backup_logs")
}

model PowerDelegation {
  id          String    @id @default(cuid())
  delegatorId String    @map("delegator_id")
  delegateId  String    @map("delegate_id")
  startDate   DateTime  @map("start_date")
  endDate     DateTime  @map("end_date")
  reason      String?
  permissions Json // string[] — ex: ["APPROVE_WORKFLOW","REJECT_WORKFLOW"]
  isActive    Boolean   @default(true) @map("is_active")
  createdById String    @map("created_by_id")
  revokedAt   DateTime? @map("revoked_at")
  revokedById String?   @map("revoked_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  delegator User     @relation("DelegatorRelation", fields: [delegatorId], references: [id])
  delegate  User     @relation("DelegateRelation", fields: [delegateId], references: [id])
  createdBy User     @relation("DelegationCreatedBy", fields: [createdById], references: [id])
  revokedBy User?    @relation("DelegationRevokedBy", fields: [revokedById], references: [id])
  companyId String?  @map("company_id")
  company   Company? @relation(fields: [companyId], references: [id])

  @@index([delegatorId])
  @@index([delegateId])
  @@index([isActive, startDate, endDate])
  @@index([companyId])
  @@map("power_delegations")
}

enum UserRole {
  CHARGE_AFFAIRES         @map("account_manager") // ex ACCOUNT_MANAGER
  ANALYSTE_RISQUES        @map("credit_analyst") // ex CREDIT_ANALYST
  RESPONSABLE_RISQUES     @map("analyst_supervisor") // ex ANALYST_SUPERVISOR
  RESPONSABLE_ENGAGEMENTS @map("branch_manager") // ex BRANCH_MANAGER
  COMITE_CREDIT           @map("credit_committee") // ex CREDIT_COMMITTEE
  DIRECTION_GENERALE      @map("management") // ex MANAGEMENT
  ADMIN                   @map("admin")
  SUPER_ADMIN             @map("super_admin")
  BACK_OFFICE             @map("back_office")
  DIRECTION_JURIDIQUE     @map("direction_juridique")
  ASSISTANT_COMMERCIAL    @map("assistant_commercial") // assistant commercial (front-office)
  DIR_AG                  @map("dir_ag") // directeur d'agence

